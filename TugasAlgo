        "# SOAL 1: KONVERSI HARI\n",
        "print(\"Konversi Hari\")\n",
        "hari = int(input(\"Masukkan Jumlah Hari: \"))\n",
        "\n",
        "tahun = hari // 365\n",
        "sisa_hari = hari % 365\n",
        "\n",
        "bulan = sisa_hari // 30\n",
        "sisa_hariakhir = sisa_hari % 30\n",
        "\n",
        "print(\"Hasil Konversi:\")\n",
        "print(\"Tahun:\", tahun)\n",
        "print(\"Bulan:\", bulan)\n",
        "print(\"Hari:\", sisa_hariakhir)"
      ],
