        "    print(\"Maksimal hanya sampai 100\")\n",
        "elif x < 1:\n",
        "    print(\"Masukkan angka minimal 1\")\n",
        "else:\n",
        "    for i in range(1, x + 1):\n",
        "        if i % 3 == 0 and i % 5 == 0:\n",
        "            print(\"FizzBuzz\")\n",
        "        elif i % 3 == 0:\n",
        "            print(\"Fizz\")\n",
        "        elif i % 5 == 0:\n",
        "            print(\"Buzz\")\n",
        "        else:\n",
        "            print(i)"
